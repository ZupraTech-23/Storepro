
<% layout('/layouts/boilerplate') %>


<body>
 


  <div class="container">
    <h2>Customers</h2>

    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>Customer Name</th>
          <th>Phone</th>
          <th>Type</th>
          <th>Created At</th>
          <th>Action</th>
        </tr>
      </thead>

      <tbody>
        <% customers.forEach(customer => { %>
          <tr>
            <td><%= customer.customer_id %></td>
            <td><%= customer.customer_name %></td>
            <td><%= customer.phone %></td>
            <td><%= customer.customer_type %></td>
            <td><%= customer.created_at.toDateString() %></td>
            <td>
              <a href="/customers/<%= customer.customer_id %>" class="btn">
                View
              </a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

</body>




